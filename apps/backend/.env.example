DATABASE_URL=postgres://<user>@localhost:5432/TreasureTrove_db
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production
COOKIE_SECRET=change-me-in-production

# CORS — comma-separated list of allowed origins.
# Dev: storefront on :3000, admin on :9000.
# Production: add the live storefront domain (e.g. https://treasuretrove.in).
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:3000,http://localhost:9000

# Production example (uncomment and extend for prod):
# STORE_CORS=http://localhost:3000,https://treasuretrove.in,https://www.treasuretrove.in
# ADMIN_CORS=http://localhost:9000,https://admin.treasuretrove.in
# AUTH_CORS=http://localhost:3000,http://localhost:9000,https://treasuretrove.in,https://admin.treasuretrove.in

PORT=9000
NODE_ENV=development

# Storefront ISR cache revalidation
# Called by product-upsert subscriber to immediately purge /products cache
# when a product is created or updated in the Medusa admin.
# Must match REVALIDATE_SECRET in apps/storefront/.env.local
STOREFRONT_URL=http://localhost:3000
REVALIDATE_SECRET=change-me-must-match-storefront

# Razorpay (INR region)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Stripe (USD + AED regions)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# MeiliSearch — product search index
# Leave MEILISEARCH_HOST unset to disable the search module in development.
# Run `POST /admin/meilisearch/sync` after enabling to perform an initial index.
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=
MEILISEARCH_PRODUCT_INDEX_NAME=products

# NeoDove CRM — outbound lead & contact push for sales follow-up
# Get the API key from: NeoDove dashboard → Settings → API
# High-value threshold is in paise (INR smallest unit): 5000000 = ₹50,000
NEODOVE_API_KEY=
NEODOVE_API_BASE_URL=https://api.neodove.com
NEODOVE_HIGH_VALUE_THRESHOLD=5000000
