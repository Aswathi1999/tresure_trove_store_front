NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
# Razorpay publishable Key ID (starts with rzp_) — safe to expose in the browser.
# The Razorpay secret stays in the backend (apps/backend/.env) and never here.
NEXT_PUBLIC_RAZORPAY_KEY_ID=
NEXT_PUBLIC_PAYLOAD_URL=http://localhost:3001
NEXT_PUBLIC_CLOUDFRONT_URL=https://cdn.treasuretrove.in
REVALIDATE_SECRET=

# QA-only: enable fixture tokens (`valid-token`, `expired-token`, `invalid-token`) at
# `/reset-password?token=...` so TC-001 can run without capturing a real Medusa JWT.
# Set to `1` on dev / staging. NEVER set on real production — it would let anyone reset
# any account's password by visiting the URL.
AUTH_QA_FIXTURES=
